# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# gemini-embedding-001 (mới) thay thế text-embedding-004 (deprecated 8/2025)
EMBEDDING_MODEL=gemini-embedding-001

# Qdrant Cloud (https://cloud.qdrant.io/)
# Dùng REST endpoint, port 6333 (KHÔNG phải 6334 vì 6334 là gRPC).
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
CHAT_COLLECTION_NAME=spa_knowledge

# Cloudinary (https://cloudinary.com/console) — lưu ảnh upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=upstore-spa
