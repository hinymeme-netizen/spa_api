# =============================================================
#  SPA API — File cau hinh moi truong (.env)
#  Sao chep file nay thanh .env roi dien cac gia tri thuc te:
#    Windows:  copy .env.example .env
#    Mac/Linux: cp .env.example .env
# =============================================================


# -------------------------------------------------------------
#  DATABASE — MySQL
#  Cai MySQL 8.x, tao database ten spa_db
#  Lenh tao DB: CREATE DATABASE spa_db CHARACTER SET utf8mb4;
# -------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=spa_db
DB_USER=root
DB_PASS=your_mysql_password


# -------------------------------------------------------------
#  JWT — Bao mat token dang nhap
#  Key phai dai it nhat 32 ky tu, random, KHONG de lo
#  Tao nhanh: openssl rand -base64 48
# -------------------------------------------------------------
JWT_KEY=your_super_secret_jwt_key_at_least_32_chars
JWT_ISSUER=SpaApi
JWT_AUDIENCE=SpaApi
JWT_EXPIRES_MINUTES=10080


# -------------------------------------------------------------
#  GEMINI AI — Google AI Studio
#  Lay API key tai: https://aistudio.google.com/apikey
#  Key dang AIzaSy... (khong phai dang AQ...)
# -------------------------------------------------------------
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001


# -------------------------------------------------------------
#  QDRANT — Vector Database (dung cho AI chat)
#  Dang ky mien phi tai: https://cloud.qdrant.io
#  Sau khi tao cluster, lay URL va API key trong dashboard
# -------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
CHAT_COLLECTION_NAME=spa_knowledge


# -------------------------------------------------------------
#  CLOUDINARY — Luu tru hinh anh upload
#  Dang ky mien phi tai: https://cloudinary.com
#  Vao Dashboard > API Keys de lay thong tin
# -------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_ROOT_FOLDER=spa-uploads


# -------------------------------------------------------------
#  GOOGLE OAUTH — Dang nhap bang Google
#  Tao tai: https://console.cloud.google.com
#  APIs & Services > Credentials > OAuth 2.0 Client IDs
#  Authorized JS origins:    http://localhost:3000
#  Authorized redirect URIs: http://localhost:5000/api/auth/google-callback
# -------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com


# -------------------------------------------------------------
#  EMAIL — Gui mail thong bao (dung Gmail SMTP)
#  Bat "Mat khau ung dung" trong tai khoan Google:
#  Tai khoan Google > Bao mat > Xac minh 2 buoc > Mat khau ung dung
# -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=your_email@gmail.com
SMTP_FROM_NAME=Ten Spa Cua Ban

# Tuy chon: Resend (dich vu email thay the Gmail)
# Dang ky tai: https://resend.com
# RESEND_API_KEY=re_your_resend_api_key


# =============================================================
#  HUONG DAN CAI DAT VA CHAY DU AN
# =============================================================
#
#  YEU CAU HE THONG:
#    - .NET SDK 8.0+   https://dotnet.microsoft.com/download
#    - MySQL 8.0+      https://dev.mysql.com/downloads/
#
#  CAC BUOC CHAY:
#
#  Buoc 1 — Sao chep va dien env:
#    copy .env.example .env
#    (dien tat ca gia tri trong file .env)
#
#  Buoc 2 — Cai EF CLI (neu chua co):
#    dotnet tool install --global dotnet-ef
#
#  Buoc 3 — Khoi phuc package:
#    dotnet restore
#
#  Buoc 4 — Tao bang database:
#    dotnet ef database update
#
#  Buoc 5 — Chay API:
#    dotnet run
#
#  API chay tai:
#    http://localhost:5000
#    http://localhost:5000/swagger  (giao dien test API)
#
#  TAI KHOAN ADMIN MAC DINH (sau seed):
#    Email:    admin@spa.local
#    Password: Admin@12345
#
# =============================================================
